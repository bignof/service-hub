  "paths": {
    "/health": {
      "get": {
        "tags": [
          "系统"
        ],
        "summary": "健康检查",
        "description": "检查服务与数据库连通性。",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "请求成功",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/agents": {
      "get": {
        "tags": [
          "Agent 管理"
        ],
        "summary": "查询全部 Agent",
        "description": "返回当前所有 Agent 的最新连接状态与在线状态。",
        "operationId": "list_agents_api_agents_get",
        "responses": {
          "200": {
            "description": "请求成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentSnapshot"
                  },
                  "title": "Response List Agents Api Agents Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Agent 管理"
        ],
        "summary": "创建 Agent 并签发初始密钥",
        "description": "创建新的 Agent 记录，并返回该 Agent 的首次连接密钥。密钥默认长期有效，直到显式轮换。",
        "operationId": "provision_agent_api_agents_post",
        "parameters": [
          {
            "name": "X-Admin-Token",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "管理令牌",
              "description": "Hub 管理令牌，值来自环境变量 ADMIN_TOKEN。"
            },
            "description": "Hub 管理令牌，值来自环境变量 ADMIN_TOKEN。"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentProvisionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "请求成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentProvisionResponse"
                }
              }
            }
          },
          "422": {
            "description": "请求校验失败",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
