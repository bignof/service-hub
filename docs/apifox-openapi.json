  "components": {
    "schemas": {
      "AgentCredentialResponse": {
        "properties": {
          "agentId": {
            "type": "string",
            "title": "Agent 标识"
          },
          "agentKey": {
            "type": "string",
            "title": "Agent 密钥"
          },
          "issuedAt": {
            "type": "string",
            "format": "date-time",
            "title": "签发时间",
            "description": "签发时间，仅用于审计；该密钥不会按时间自动过期，直到被轮换。"
          },
          "created": {
            "type": "boolean",
            "title": "是否为首次创建"
          }
        },
        "type": "object",
        "required": [
          "agentId",
          "agentKey",
          "issuedAt",
          "created"
        ],
        "title": "Agent 凭据响应"
      },
      "AgentProvisionRequest": {
        "properties": {
          "agentId": {
            "type": "string",
            "title": "Agent 标识"
          }
        },
        "type": "object",
        "required": [
          "agentId"
        ],
        "title": "创建 Agent 请求"
      },
      "AgentProvisionResponse": {
        "properties": {
          "agent": {
            "$ref": "#/components/schemas/AgentSnapshot",
            "title": "Agent 信息"
          },
          "agentKey": {
            "type": "string",
            "title": "Agent 密钥"
          },
          "issuedAt": {
            "type": "string",
            "format": "date-time",
            "title": "签发时间",
            "description": "签发时间，仅用于审计；该密钥不会按时间自动过期，直到被轮换。"
          }
        },
        "type": "object",
        "required": [
          "agent",
          "agentKey",
          "issuedAt"
        ],
        "title": "创建 Agent 响应"
      },
      "AgentSnapshot": {
        "properties": {
          "agentId": {
            "type": "string",
            "title": "Agent 标识"
          },
          "connected": {
            "type": "boolean",
            "title": "是否已连接"
          },
          "online": {
            "type": "boolean",
            "title": "是否在线"
          },
          "credentialConfigured": {
            "type": "boolean",
            "title": "是否已配置凭据"
          },
          "remote": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "远端地址"
          },
          "keyIssuedAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "密钥签发时间",
            "description": "最近一次签发时间，仅用于审计，不代表过期时间。"
          },
          "connectedAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "连接时间"
          },
          "disconnectedAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "断开时间"
          },
          "lastSeenAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "最后活跃时间"
          },
          "lastHeartbeatAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "最后心跳时间"
          },
          "lastPongAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "最后 Pong 时间"
          },
          "staleAfterSeconds": {
            "type": "integer",
            "title": "离线判定秒数"
          },
          "queuedCommands": {
            "type": "integer",
            "title": "排队中的命令数",
            "default": 0
          },
          "processingCommands": {
            "type": "integer",
            "title": "执行中的命令数",
            "default": 0
          },
          "lastCommandCreatedAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
